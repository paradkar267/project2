<% layout('layouts/boilerplate') %>

    <div class="row">
        <div class="col-8 offset-2">
            <br><br>

            <h3>Create New Listing</h3>
            <form action="/listings" method="POST" novalidate class="needs-validation" enctype="multipart/form-data">
                <div class="mb-3">
                    <label for="title" class="form-label">Title</label>
                    <input name="listing[title]" type="text" placeholder="Title name" class="form-control" required />
                    <div class="valid-feedback">title look good</div>

                </div>

                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea name="listing[description]" class="form-control" required></textarea>
                </div>


                <div class="mb-3">
                    <label for="image" class="form-label">Upload Listing Image</label>
                    <input name="listing[image]" type="file" class="form-control" required />
                </div>


                <div class="row">
                    <div class="mb-3 col-md-4">
                        <label for="price" class="form-label">Price</label>
                        <input name="listing[price]" type="number" placeholder=" Enter Price" class="form-control"
                            required />
                        <div class="invalid-feedback">please enter a valid price</div>
                    </div>

                    <div class="mb-3 col-8">
                        <label for="country" class="form-label">Country</label>
                        <input name="listing[country]" type="text" placeholder=" Enter Country" class="form-control"
                            required />

                        <div class="invalid-feedback">please enter a valid country</div>
                    </div>

                </div>
                <div class="mb-3">
                    <label for="location" class="form-label">Location</label>
                    <input name="listing[location]" type="text" placeholder=" Enter Location" class="form-control"
                        required />
                    <div class="invalid-feedback">please enter a valid location</div>
                </div>
                <div class="mb-3">
                    <label for="category" class="form-label">Category</label>
                    <select name="listing[category]" class="form-select" required>
                        <option value="" disabled selected>Select a category</option>
                        <% for (let category of categories) { %>
                            <option value="<%= category %>"><%= category.charAt(0).toUpperCase() + category.slice(1) %></option>
                        <% } %>
                    </select>
                    <div class="invalid-feedback">please select a category</div>
                </div>
                <br>
                <button type="submit" class="btn btn-dark add-btn">Create Listing</button>
            </form>

        </div>
    </div>
